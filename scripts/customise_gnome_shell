    # [screenshot-window]="[]"
    [shift-overview-down]="['<Super><Ctrl>n']"
    [shift-overview-up]="['<Super><Ctrl>p']"
    [show-screen-recording-ui]="['<Super><Ctrl>r']"
    [show-screenshot-ui]="['<Super><Ctrl>s']"
    # [switch-to-application-1]="[]"
    # [switch-to-application-2]="[]"
    # [switch-to-application-3]="[]"
    # [switch-to-application-4]="[]"
