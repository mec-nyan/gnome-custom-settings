}

_disable_ibus_emoji() {

  # Disable ibus emoji/unicode to avoid conflicts.
  # NOTE: set ibus emoji/unicode to a different key (it may be useful!).
  gsettings set org.freedesktop.ibus.panel.emoji unicode-hotkey "['']"
  gsettings set org.freedesktop.ibus.panel.emoji hotkey "['']"
}

set_keybindings() {

  _disable_ibus_emoji

  _set_wm_keybindings

  _set_shell_keybindings
}
